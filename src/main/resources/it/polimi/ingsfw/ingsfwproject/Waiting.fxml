   </Text>
   <TextArea fx:id="newPlayerJoined" editable="false" layoutX="776.0" layoutY="212.0" prefHeight="208.0" prefWidth="404.0" style="-fx-background-color: #e6ddbc;" stylesheets="@Style.css">
