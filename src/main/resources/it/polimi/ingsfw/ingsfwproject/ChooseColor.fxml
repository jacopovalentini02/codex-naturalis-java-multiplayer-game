      <Rectangle fx:id="yellowRectangle" arcHeight="5.0" arcWidth="5.0" fill="#ebf55e" height="96.0" layoutX="1090.0" layoutY="430.0" onMouseClicked="#yellowChosen" stroke="TRANSPARENT" strokeType="INSIDE" visible="false" width="101.0" />
